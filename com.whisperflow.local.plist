<?xml version="1.0" encoding="UTF-8"?>
<!--
  Template LaunchAgent plist for Just Voice Type.

  Placeholders __PROJECT_DIR__ and __HF_HOME__ are replaced by
  install_autostart.sh at install time. The rendered file is copied
  into ~/Library/LaunchAgents/. Do not load this file directly.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.whisperflow.local</string>

    <key>ProgramArguments</key>
    <array>
        <string>__PROJECT_DIR__/.venv/bin/python3</string>
        <string>__PROJECT_DIR__/whisper_flow_app.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__PROJECT_DIR__</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>StandardOutPath</key>
    <string>__PROJECT_DIR__/whisper_flow.log</string>

    <key>StandardErrorPath</key>
    <string>__PROJECT_DIR__/whisper_flow.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin</string>
        <key>HF_HOME</key>
        <string>__HF_HOME__</string>
    </dict>

    <key>ProcessType</key>
    <string>Interactive</string>

    <key>Nice</key>
    <integer>0</integer>
</dict>
</plist>
